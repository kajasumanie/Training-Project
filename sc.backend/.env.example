# Backend Environment Variables

# Server Configuration
PORT=3000

# JWT Secrets
JWT_ACCESS_TOKEN_SECRET=your-super-secret-jwt-key-change-this-in-production-12345
JWT_REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-this-in-production-67890

# Database Configuration (SQLite - no additional config needed)
# The database file will be created as database.sqlite in the root directory
